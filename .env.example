# .env.example
# ─── App ─────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Database ────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/adcraft_ai

# ─── Clerk ───────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── AI - Text Models ─────────────────────────
DEFAULT_AI_PROVIDER=claude          # claude | openai | gemini
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=AIza...

# ─── AI - Video Models ────────────────────────
DEFAULT_VIDEO_PROVIDER=runway       # runway | kling | pika | luma
RUNWAY_API_KEY=...
KLING_API_KEY=...
PIKA_API_KEY=...
LUMA_API_KEY=...

# ─── Cloudflare R2 ───────────────────────────
CLOUDFLARE_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=adcraft-ai
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ─── Stripe ──────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

STRIPE_STARTER_MONTHLY_PRICE_ID=price_...
STRIPE_STARTER_YEARLY_PRICE_ID=price_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...
STRIPE_AGENCY_MONTHLY_PRICE_ID=price_...
STRIPE_AGENCY_YEARLY_PRICE_ID=price_...
